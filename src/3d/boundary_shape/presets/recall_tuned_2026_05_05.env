# BoundaryOverseg recall-tuned defaults used for the 2026-05-05 run.
# This run improved case_0004 recall but over-softened FP suppression overall.
export NNUNET_BOUNDARY_OVERSEG_EPOCHS=50
export NNUNET_BOUNDARY_OVERSEG_LR=3e-4
export NNUNET_BOUNDARY_OVERSEG_BOUNDARY_WEIGHT=0.10
export NNUNET_BOUNDARY_OVERSEG_OVERSEG_WEIGHT=0.05
export NNUNET_BOUNDARY_OVERSEG_OUTSIDE_LIVER_FP_WEIGHT=2.0
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_FP_WEIGHT=0.25
export NNUNET_BOUNDARY_OVERSEG_BOUNDARY_RADIUS=2
export NNUNET_BOUNDARY_OVERSEG_OUTSIDE_LIVER_IGNORE_RADIUS=2
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_IGNORE_RADIUS=4
export NNUNET_BOUNDARY_OVERSEG_OUTSIDE_LIVER_TOPK_FRACTION=0.01
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_TOPK_FRACTION=0.002
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_VOLUME_GUARD_THRESHOLD=0.05
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_VOLUME_GUARD_MIN_SCALE=0.03
export NNUNET_BOUNDARY_OVERSEG_TVERSKY_GUARD_WEIGHT=0.10
export NNUNET_BOUNDARY_OVERSEG_TVERSKY_GUARD_ALPHA=0.20
export NNUNET_BOUNDARY_OVERSEG_TVERSKY_GUARD_BETA=0.80
export NNUNET_BOUNDARY_OVERSEG_BOUNDARY_START_EPOCH=5
export NNUNET_BOUNDARY_OVERSEG_FP_START_EPOCH=10
export NNUNET_BOUNDARY_OVERSEG_RAMP_EPOCHS=10
