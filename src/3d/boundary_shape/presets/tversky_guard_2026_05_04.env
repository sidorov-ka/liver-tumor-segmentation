export NNUNET_BOUNDARY_OVERSEG_OUTSIDE_LIVER_FP_WEIGHT=4.0
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_FP_WEIGHT=0.5
export NNUNET_BOUNDARY_OVERSEG_BOUNDARY_RADIUS=2
export NNUNET_BOUNDARY_OVERSEG_OUTSIDE_LIVER_IGNORE_RADIUS=2
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_IGNORE_RADIUS=4
export NNUNET_BOUNDARY_OVERSEG_OUTSIDE_LIVER_TOPK_FRACTION=0.01
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_TOPK_FRACTION=0.002
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_VOLUME_GUARD_THRESHOLD=0.02
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_VOLUME_GUARD_MIN_SCALE=0.10
export NNUNET_BOUNDARY_OVERSEG_TVERSKY_GUARD_WEIGHT=0.05
export NNUNET_BOUNDARY_OVERSEG_TVERSKY_GUARD_ALPHA=0.30
export NNUNET_BOUNDARY_OVERSEG_TVERSKY_GUARD_BETA=0.70
export NNUNET_BOUNDARY_OVERSEG_BOUNDARY_START_EPOCH=5
export NNUNET_BOUNDARY_OVERSEG_FP_START_EPOCH=10
