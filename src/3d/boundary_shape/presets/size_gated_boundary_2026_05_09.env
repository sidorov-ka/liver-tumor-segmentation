# BoundaryOverseg size-gated defaults for the next experiment.
# Starts from the saved-good Tversky run and fades all custom loss terms on
# high tumor-burden patches so large tumors stay close to default fine-tuning.
export NNUNET_BOUNDARY_OVERSEG_EPOCHS=50
export NNUNET_BOUNDARY_OVERSEG_LR=1e-3
export NNUNET_BOUNDARY_OVERSEG_BOUNDARY_WEIGHT=0.10
export NNUNET_BOUNDARY_OVERSEG_OVERSEG_WEIGHT=0.05
export NNUNET_BOUNDARY_OVERSEG_OUTSIDE_LIVER_FP_WEIGHT=4.0
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_FP_WEIGHT=0.5
export NNUNET_BOUNDARY_OVERSEG_BOUNDARY_RADIUS=2
export NNUNET_BOUNDARY_OVERSEG_OUTSIDE_LIVER_IGNORE_RADIUS=2
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_IGNORE_RADIUS=4
export NNUNET_BOUNDARY_OVERSEG_OUTSIDE_LIVER_TOPK_FRACTION=0.01
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_TOPK_FRACTION=0.002
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_VOLUME_GUARD_THRESHOLD=0.02
export NNUNET_BOUNDARY_OVERSEG_INSIDE_LIVER_VOLUME_GUARD_MIN_SCALE=0.10
export NNUNET_BOUNDARY_OVERSEG_TVERSKY_GUARD_WEIGHT=0.05
export NNUNET_BOUNDARY_OVERSEG_TVERSKY_GUARD_ALPHA=0.30
export NNUNET_BOUNDARY_OVERSEG_TVERSKY_GUARD_BETA=0.70
export NNUNET_BOUNDARY_OVERSEG_ADAPTIVE_LARGE_TUMOR_THRESHOLD=0.02
export NNUNET_BOUNDARY_OVERSEG_ADAPTIVE_LARGE_TUMOR_MAX_THRESHOLD=0.10
export NNUNET_BOUNDARY_OVERSEG_ADAPTIVE_FP_MIN_SCALE=1.0
export NNUNET_BOUNDARY_OVERSEG_ADAPTIVE_IGNORE_EXTRA_RADIUS=0
export NNUNET_BOUNDARY_OVERSEG_UNDER_VOLUME_GUARD_WEIGHT=0.0
export NNUNET_BOUNDARY_OVERSEG_UNDER_VOLUME_GUARD_THRESHOLD=0.05
export NNUNET_BOUNDARY_OVERSEG_UNDER_VOLUME_GUARD_FRACTION=0.85
export NNUNET_BOUNDARY_OVERSEG_CUSTOM_LOSS_GATE_THRESHOLD=0.04
export NNUNET_BOUNDARY_OVERSEG_CUSTOM_LOSS_GATE_TEMPERATURE=0.015
export NNUNET_BOUNDARY_OVERSEG_CUSTOM_LOSS_GATE_MIN_SCALE=0.0
export NNUNET_BOUNDARY_OVERSEG_BOUNDARY_START_EPOCH=5
export NNUNET_BOUNDARY_OVERSEG_FP_START_EPOCH=10
export NNUNET_BOUNDARY_OVERSEG_RAMP_EPOCHS=10
